# =====================================================================
#  reading_reels environment variables   (copy to .env and fill in)
#  EVERYTHING here is OPTIONAL. With no keys the tool still runs using
#  a local content engine + generated gradient backgrounds + offline/no audio.
# =====================================================================

# --- AI script generation (free for prototyping) -------------------
# Get a key at https://build.nvidia.com  -> any model card -> "Get API Key"
# Key looks like:  nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_KEY=

# --- Backgrounds (free tiers) --------------------------------------
# Pexels  : https://www.pexels.com/api/   (free, generous)
PEXELS_API_KEY=
# Pixabay : https://pixabay.com/api/docs/ (free)
PIXABAY_API_KEY=

# --- Telegram bot (required) --------------------------------------
# Get a token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID (get from @userinfobot)
# TELEGRAM_CHAT_ID=

# --- Optional overrides --------------------------------------------
# Override the NIM model (default set in config/config.yaml)
# NIM_MODEL=meta/llama-3.1-70b-instruct
